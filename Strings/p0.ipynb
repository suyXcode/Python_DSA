   "source": [
    "**Valid Parentheses**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "17571879",
   "metadata": {
    "vscode": {
     "languageId": "python"
    }
   },
   "outputs": [],
   "source": [
    "def isValid(s):\n",
    "    st=[]\n",
    "    mp={')':'(',']':'[','}':'{'}\n",
    "    for c in s:\n",
    "        if c in mp:\n",
    "            if not st or st[-1]!=mp[c]:\n",
    "                return False\n",
    "            st.pop()\n",
    "        else:\n",
    "            st.append(c)\n",
    "    return not st"
   ]
